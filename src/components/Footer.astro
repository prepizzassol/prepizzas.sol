---
const {
  instagram = "https://www.instagram.com/casero.sp/",
  whatsapp = "https://wa.me/5491133544047?text=Hola%20!%20Quiero%20hacer%20un%20pedido%20de%20prepizzas%20",
  email = "mailto:prepizzas.sol@gmail.com",
  year = new Date().getFullYear(),
} = Astro.props;
---

<footer class="relative overflow-hidden bg-bg mt-10">
  <div
    class="relative z-[3] container py-10 flex flex-col md:flex-row justify-between items-center gap-5 text-center md:text-left"
  >
    <div
      class="flex flex-col gap-2 mx-auto md:mx-0 items-center md:items-start text-center md:text-left"
    >
      <a
        href="#inicio"
        class="flex flex-col items-center justify-center hover:scale-105 transition-transform mb-2"
      >
        <span class="font-display tracking-normal text-text text-5xl font-bold"
          >Casero S.P</span
        >
      </a>
      <p class="text-sm text-muted font-bold">
        Hechas con amor desde Villa Adelina
      </p>
    </div>

    <!-- Links -->
    <nav class="flex flex-wrap justify-center gap-6">
      <a
        href="#inicio"
        class="text-base hover:text-accent font-bold transition-colors font-sans"
        >Inicio</a
      >
      <a
        href="#sabores"
        class="text-base hover:text-accent font-bold transition-colors font-sans"
        >Sabores</a
      >
      <a
        href="#galeria"
        class="text-base hover:text-accent font-bold transition-colors font-sans"
        >Galería</a
      >
      <a
        href="#contacto"
        class="text-base hover:text-accent font-bold transition-colors font-sans"
        >Contacto</a
      >
    </nav>

    <!-- Redes -->
    <div class="flex gap-4 items-center justify-center">
      <a
        href={instagram}
        target="_blank"
        rel="noopener"
        aria-label="Instagram"
        class="hover:scale-110 transition-transform bg-white scrapbook-border scrapbook-shadow p-2 rounded-full"
      >
        <img
          src="/icons/instagram.svg"
          alt="Instagram"
          class="w-6 h-6 opacity-80 hover:opacity-100"
        />
      </a>
      <a
        href={whatsapp}
        target="_blank"
        rel="noopener"
        aria-label="WhatsApp"
        class="hover:scale-110 transition-transform bg-white scrapbook-border scrapbook-shadow p-2 rounded-full"
      >
        <img
          src="/icons/whatsapp.svg"
          alt="WhatsApp"
          class="w-6 h-6 opacity-80 hover:opacity-100"
        />
      </a>
      <a
        href={email}
        aria-label="Correo"
        class="hover:scale-110 transition-transform bg-white scrapbook-border scrapbook-shadow p-2 rounded-full"
      >
        <img
          src="/icons/mail.svg"
          alt="Correo"
          class="w-6 h-6 opacity-80 hover:opacity-100"
        />
      </a>
    </div>
  </div>

  <div class="relative z-[3] py-4 text-center text-sm font-bold text-muted/70">
    © {year} Casero S.P — Todos los derechos reservados.
  </div>
</footer>
