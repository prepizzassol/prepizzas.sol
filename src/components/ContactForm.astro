---
const {
  title = 'Hacé tu pedido',
  copy = 'Contanos qué opción te gusta y coordinamos por WhatsApp.',
  web3formsKey = 'a33e18e3-45d7-43d5-bc10-121df773418d',
  whatsapp = 'https://wa.me/5491133544047?text=Hola%20!%20Quiero%20hacer%20un%20pedido%20de%20prepizzas%20',
} = Astro.props;
---

<section id="contacto" class="relative overflow-hidden bg-bg py-16 md:py-24">
  <div class="container relative z-[3] flex flex-col items-center gap-10">
    <!-- Texto -->
    <div class="flex flex-col gap-4 text-center max-w-2xl md:text-lg">
      <h2 class="font-display text-text text-5xl md:text-6xl font-bold">{title}</h2>
      <p class="text-muted font-bold text-xl">{copy}</p>
      <div class="bg-yellow scrapbook-border scrapbook-shadow inline-block p-4 mt-2">
        <ul class="text-sm md:text-base text-text font-medium list-disc space-y-1 text-left inline-block w-fit self-center px-4">
          <li>Respondo a la brevedad confirmando tu pedido.</li>
          <li>Podés combinar <strong>prepizzas</strong>, <strong>pizzetas</strong> y <strong>empanadas</strong> como prefieras.</li>
        </ul>
      </div>
    </div>

    <!-- Formulario -->
    <form
      id="pedidoForm"
      class="bg-white rounded-3xl scrapbook-shadow scrapbook-border p-6 md:p-10 space-y-6 w-full max-w-3xl"
      method="POST"
      action="https://api.web3forms.com/submit"
      novalidate
    >
      <!-- Web3Forms: campos ocultos -->
      <input type="hidden" name="access_key" value={web3formsKey} />
      <input type="hidden" name="subject" value="Nuevo pedido desde la landing casero.sp" />
      <input type="hidden" name="from_name" value="casero.sp" />

      <!-- Honeypot anti-bot -->
      <input type="text" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />

      <!-- Nombre -->
      <div>
        <label for="nombre" class="block text-lg font-display font-bold text-text mb-1">Nombre*</label>
        <input id="nombre" name="name" required placeholder="Tu nombre"
          class="w-full rounded-2xl border-2 border-text px-4 py-3 outline-none focus:ring-2 focus:ring-accent bg-bg font-medium text-text"
        />
        <p data-err-for="nombre" class="mt-1 text-sm text-[#b00020] hidden">Ingresá tu nombre.</p>
      </div>

      <!-- Teléfono / WhatsApp -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label for="telefono" class="block text-lg font-display font-bold text-text mb-1">Teléfono / WhatsApp*</label>
          <input id="telefono" name="phone" required inputmode="tel" placeholder="11 1234 5678"
            class="w-full rounded-2xl border-2 border-text px-4 py-3 outline-none focus:ring-2 focus:ring-accent bg-bg font-medium text-text"
          />
          <p data-err-for="telefono" class="mt-1 text-sm text-[#b00020] hidden">Ingresá un teléfono válido.</p>
        </div>
        <div>
          <label for="email" class="block text-lg font-display font-bold text-text mb-1">Email</label>
          <input id="email" type="email" name="email" placeholder="tu@email.com"
            class="w-full rounded-2xl border-2 border-text px-4 py-3 outline-none focus:ring-2 focus:ring-accent bg-bg font-medium text-text"
          />
        </div>
      </div>

      <!-- Productos -->
      <div id="productos-container" class="space-y-6">
        <!-- Prepizzas -->
        <div class="bg-green/20 p-5 rounded-2xl border-2 border-green border-dashed">
          <h3 class="font-bold text-xl font-display text-text mb-4">Prepizzas</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-x-6 gap-y-4">
            <label class="flex justify-between items-center gap-3">
              <span class="text-sm font-bold text-text leading-tight">Tomate</span>
              <div class="flex items-center gap-2 bg-white rounded-full border-2 border-text p-1 shrink-0">
                <button type="button" class="w-7 h-7 rounded-full bg-bg flex items-center justify-center font-bold text-lg hover:bg-yellow text-text leading-none transition-colors" onclick="this.nextElementSibling.stepDown()">-</button>
                <input type="number" min="0" value="0" data-name="Prepizza(s) de Tomate" class="producto-qty w-8 text-center bg-transparent font-bold outline-none text-sm p-0 text-text" readonly />
                <button type="button" class="w-7 h-7 rounded-full bg-bg flex items-center justify-center font-bold text-lg hover:bg-yellow text-text leading-none transition-colors" onclick="this.previousElementSibling.stepUp()">+</button>
              </div>
            </label>
            <label class="flex justify-between items-center gap-3">
              <span class="text-sm font-bold text-text leading-tight">Cebolla (Fugazza)</span>
              <div class="flex items-center gap-2 bg-white rounded-full border-2 border-text p-1 shrink-0">
                <button type="button" class="w-7 h-7 rounded-full bg-bg flex items-center justify-center font-bold text-lg hover:bg-yellow text-text leading-none transition-colors" onclick="this.nextElementSibling.stepDown()">-</button>
                <input type="number" min="0" value="0" data-name="Prepizza(s) de Cebolla" class="producto-qty w-8 text-center bg-transparent font-bold outline-none text-sm p-0 text-text" readonly />
                <button type="button" class="w-7 h-7 rounded-full bg-bg flex items-center justify-center font-bold text-lg hover:bg-yellow text-text leading-none transition-colors" onclick="this.previousElementSibling.stepUp()">+</button>
              </div>
            </label>
            <label class="flex justify-between items-center gap-3">
              <span class="text-sm font-bold text-text leading-tight">Mixta</span>
              <div class="flex items-center gap-2 bg-white rounded-full border-2 border-text p-1 shrink-0">
                <button type="button" class="w-7 h-7 rounded-full bg-bg flex items-center justify-center font-bold text-lg hover:bg-yellow text-text leading-none transition-colors" onclick="this.nextElementSibling.stepDown()">-</button>
                <input type="number" min="0" value="0" data-name="Prepizza(s) Mixta(s)" class="producto-qty w-8 text-center bg-transparent font-bold outline-none text-sm p-0 text-text" readonly />
                <button type="button" class="w-7 h-7 rounded-full bg-bg flex items-center justify-center font-bold text-lg hover:bg-yellow text-text leading-none transition-colors" onclick="this.previousElementSibling.stepUp()">+</button>
              </div>
            </label>
          </div>
        </div>

        <!-- Pizzetas -->
        <div id="pizzetas-container" class="bg-purple/20 p-5 rounded-2xl border-2 border-purple border-dashed">
          <div class="flex justify-between items-baseline mb-4">
            <h3 class="font-bold text-xl font-display text-text">Pizzetas</h3>
            <span class="text-xs font-bold text-muted">(Mín. 12 uds)</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
            <label class="flex justify-between items-center gap-3">
              <span class="text-sm font-bold text-text leading-tight">Cebolla</span>
              <div class="flex items-center gap-2 bg-white rounded-full border-2 border-text p-1 shrink-0">
                <button type="button" class="w-7 h-7 rounded-full bg-bg flex items-center justify-center font-bold text-lg hover:bg-yellow text-text leading-none transition-colors" onclick="this.nextElementSibling.stepDown()">-</button>
                <input type="number" min="0" step="6" value="0" data-name="Pizzetas Cebolla" class="producto-qty w-8 text-center bg-transparent font-bold outline-none text-sm p-0 text-text" readonly />
                <button type="button" class="w-7 h-7 rounded-full bg-bg flex items-center justify-center font-bold text-lg hover:bg-yellow text-text leading-none transition-colors" onclick="this.previousElementSibling.stepUp()">+</button>
              </div>
            </label>
            <label class="flex justify-between items-center gap-3">
              <span class="text-sm font-bold text-text leading-tight">Tomate</span>
              <div class="flex items-center gap-2 bg-white rounded-full border-2 border-text p-1 shrink-0">
                <button type="button" class="w-7 h-7 rounded-full bg-bg flex items-center justify-center font-bold text-lg hover:bg-yellow text-text leading-none transition-colors" onclick="this.nextElementSibling.stepDown()">-</button>
                <input type="number" min="0" step="6" value="0" data-name="Pizzetas Tomate" class="producto-qty w-8 text-center bg-transparent font-bold outline-none text-sm p-0 text-text" readonly />
                <button type="button" class="w-7 h-7 rounded-full bg-bg flex items-center justify-center font-bold text-lg hover:bg-yellow text-text leading-none transition-colors" onclick="this.previousElementSibling.stepUp()">+</button>
              </div>
            </label>
          </div>
          <p data-err-for="pizzetas" class="mt-2 text-sm text-[#b00020] hidden font-medium">Las pizzetas se piden con un mínimo de 1 docena (12 uds).</p>
        </div>

        <!-- Empanadas -->
        <div id="empanadas-container" class="bg-accent/20 p-5 rounded-2xl border-2 border-accent border-dashed">
          <div class="flex justify-between items-baseline mb-4">
            <h3 class="font-bold text-xl font-display text-text">Empanadas</h3>
            <span class="text-xs font-bold text-muted">(Mín. 12 uds)</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-4">
            <label class="flex justify-between items-center gap-3">
              <span class="text-sm font-bold text-text leading-tight">Muzzarella y Jamón</span>
              <div class="flex items-center gap-2 bg-white rounded-full border-2 border-text p-1 shrink-0">
                <button type="button" class="w-7 h-7 rounded-full bg-bg flex items-center justify-center font-bold text-lg hover:bg-yellow text-text leading-none transition-colors" onclick="this.nextElementSibling.stepDown()">-</button>
                <input type="number" min="0" step="6" value="0" data-name="Empanadas Muzzarella y Jamón" class="producto-qty w-8 text-center bg-transparent font-bold outline-none text-sm p-0 text-text" readonly />
                <button type="button" class="w-7 h-7 rounded-full bg-bg flex items-center justify-center font-bold text-lg hover:bg-yellow text-text leading-none transition-colors" onclick="this.previousElementSibling.stepUp()">+</button>
              </div>
            </label>
            <label class="flex justify-between items-center gap-3">
              <span class="text-sm font-bold text-text leading-tight">Muzzarella y Verdura</span>
              <div class="flex items-center gap-2 bg-white rounded-full border-2 border-text p-1 shrink-0">
                <button type="button" class="w-7 h-7 rounded-full bg-bg flex items-center justify-center font-bold text-lg hover:bg-yellow text-text leading-none transition-colors" onclick="this.nextElementSibling.stepDown()">-</button>
                <input type="number" min="0" step="6" value="0" data-name="Empanadas Verdura" class="producto-qty w-8 text-center bg-transparent font-bold outline-none text-sm p-0 text-text" readonly />
                <button type="button" class="w-7 h-7 rounded-full bg-bg flex items-center justify-center font-bold text-lg hover:bg-yellow text-text leading-none transition-colors" onclick="this.previousElementSibling.stepUp()">+</button>
              </div>
            </label>
            <label class="flex justify-between items-center gap-3">
              <span class="text-sm font-bold text-text leading-tight">Muzzarella y Cebolla</span>
              <div class="flex items-center gap-2 bg-white rounded-full border-2 border-text p-1 shrink-0">
                <button type="button" class="w-7 h-7 rounded-full bg-bg flex items-center justify-center font-bold text-lg hover:bg-yellow text-text leading-none transition-colors" onclick="this.nextElementSibling.stepDown()">-</button>
                <input type="number" min="0" step="6" value="0" data-name="Empanadas Cebolla y Queso" class="producto-qty w-8 text-center bg-transparent font-bold outline-none text-sm p-0 text-text" readonly />
                <button type="button" class="w-7 h-7 rounded-full bg-bg flex items-center justify-center font-bold text-lg hover:bg-yellow text-text leading-none transition-colors" onclick="this.previousElementSibling.stepUp()">+</button>
              </div>
            </label>
            <label class="flex justify-between items-center gap-3">
              <span class="text-sm font-bold text-text leading-tight">Caprese</span>
              <div class="flex items-center gap-2 bg-white rounded-full border-2 border-text p-1 shrink-0">
                <button type="button" class="w-7 h-7 rounded-full bg-bg flex items-center justify-center font-bold text-lg hover:bg-yellow text-text leading-none transition-colors" onclick="this.nextElementSibling.stepDown()">-</button>
                <input type="number" min="0" step="6" value="0" data-name="Empanadas Caprese" class="producto-qty w-8 text-center bg-transparent font-bold outline-none text-sm p-0 text-text" readonly />
                <button type="button" class="w-7 h-7 rounded-full bg-bg flex items-center justify-center font-bold text-lg hover:bg-yellow text-text leading-none transition-colors" onclick="this.previousElementSibling.stepUp()">+</button>
              </div>
            </label>
          </div>
          <p data-err-for="empanadas" class="mt-2 text-sm text-[#b00020] hidden font-medium">Las empanadas se piden con un mínimo de 1 docena (12 uds).</p>
        </div>

        <!-- Entrega -->
        <div class="bg-yellow/20 p-5 rounded-2xl border-2 border-yellow border-dashed">
          <label class="block text-lg font-display font-bold text-text mb-3">Entrega</label>
          <div class="flex flex-wrap gap-6 items-center">
            <label class="inline-flex items-center gap-2 cursor-pointer font-bold text-text">
              <input type="radio" name="entrega" value="Retiro por local" class="accent-text w-5 h-5" checked />
              <span>Retiro por local</span>
            </label>
            <label class="inline-flex items-center gap-2 cursor-pointer font-bold text-text">
              <input type="radio" name="entrega" value="Envío (consultar costo)" class="accent-text w-5 h-5" />
              <span>Envío (consultar)</span>
            </label>
          </div>
        </div>

        <p data-err-for="productos" class="mt-1 text-sm text-[#b00020] hidden font-bold">Por favor agregá al menos 1 producto a tu pedido.</p>
        <!-- Campo oculto para enviar todo el detalle junto en Web3Forms -->
        <input type="hidden" name="Detalle_de_Pedido" id="detalle_pedido_hidden" />
      </div>

      <!-- Mensaje -->
      <div>
        <label for="mensaje" class="block text-lg font-display font-bold text-text mb-1">Mensaje Opcional</label>
        <textarea id="mensaje" name="message" rows="3" placeholder="Ej: Para el viernes por la noche."
          class="w-full rounded-2xl border-2 border-text px-4 py-3 outline-none focus:ring-2 focus:ring-accent bg-bg font-medium text-text"></textarea>
      </div>

      <!-- Estado -->
      <div class="text-sm">
        <span id="formState" class="text-muted font-bold" aria-live="polite"></span>
      </div>

      <!-- Acciones -->
      <div class="flex flex-col sm:flex-row items-center gap-4 mt-6">
        <button
          id="whatsappLinkBtn"
          type="button"
          class="btn flex-1 w-full text-center bg-[#25D366] text-text"
        >
          Enviar por WhatsApp
        </button>
        <button
          id="submitBtn"
          type="submit"
          class="btn flex-1 w-full text-center bg-white text-text"
        >Enviar por email</button>
      </div>
    </form>
  </div>

  <style>
    input[type="number"]::-webkit-inner-spin-button, 
    input[type="number"]::-webkit-outer-spin-button { 
        -webkit-appearance: none; 
        margin: 0; 
    }
    input[type="number"] {
        -moz-appearance: textfield;
    }
  </style>

  <!-- Script: validación + envío fetch a Web3Forms + feedback -->
  <script is:inline>
    const form = document.getElementById('pedidoForm');
    const state = document.getElementById('formState');
    const submitBtn = document.getElementById('submitBtn');
    const wppBtn = document.getElementById('whatsappLinkBtn');

    const showError = (id) => {
      const p = document.querySelector(`[data-err-for="${id}"]`);
      p?.classList.remove('hidden');
    };
    const clearErrors = () => {
      document.querySelectorAll('[data-err-for]').forEach(el => el.classList.add('hidden'));
    };

    const getOrderDetails = () => {
      const inputs = document.querySelectorAll('.producto-qty');
      let details = [];
      let totalItems = 0;
      inputs.forEach(input => {
        const qty = parseInt(input.value) || 0;
        if (qty > 0) {
          details.push(`- ${qty}x ${input.getAttribute('data-name')}`);
          totalItems += qty;
        }
      });
      return { text: details.join('\n'), totalItems };
    };

    const isFormValid = () => {
      clearErrors();
      const nombre = /** @type {HTMLInputElement} */(document.getElementById('nombre'));
      const tel = /** @type {HTMLInputElement} */(document.getElementById('telefono'));
      let ok = true;

      if (!nombre.value.trim()) { showError('nombre'); ok = false; }
      if (!tel.value.trim())    { showError('telefono'); ok = false; }

      const order = getOrderDetails();

      const getCategoryTotal = (containerSelector) => {
        let total = 0;
        document.querySelectorAll(`${containerSelector} .producto-qty`).forEach(input => {
          total += parseInt(input.value) || 0;
        });
        return total;
      };

      const empanadasTotal = getCategoryTotal('#empanadas-container');
      const pizzetasTotal = getCategoryTotal('#pizzetas-container');

      if (empanadasTotal > 0 && empanadasTotal < 12) {
        showError('empanadas');
        ok = false;
      }
      if (pizzetasTotal > 0 && pizzetasTotal < 12) {
        showError('pizzetas');
        ok = false;
      }

      if (order.totalItems === 0) {
        showError('productos');
        ok = false;
      }

      return { ok, order, nombre: nombre.value.trim(), tel: tel.value.trim() };
    };

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const { ok, order } = isFormValid();
      if (!ok) {
        state.textContent = 'Revisá los campos marcados.';
        return;
      }

      // Preparar payload
      const detalleInput = document.getElementById('detalle_pedido_hidden');
      detalleInput.value = "\n" + order.text;
      
      const data = new FormData(form);

      // UX: deshabilitar mientras envía
      submitBtn.disabled = true;
      submitBtn.classList.add('opacity-70', 'cursor-not-allowed');
      state.textContent = 'Enviando…';

      try {
        const res = await fetch(form.action, { method: 'POST', body: data });
        const json = await res.json();

        if (json.success) {
          state.textContent = '¡Listo! Te contactamos a la brevedad.';
          form.reset();
          document.querySelectorAll('.producto-qty').forEach(i => i.value = '0');
        } else {
          state.textContent = 'No se pudo enviar. Probá de nuevo o escribime por WhatsApp.';
          console.error('Web3Forms error:', json);
        }
      } catch (err) {
        state.textContent = 'Ocurrió un error al enviar. Probá de nuevo más tarde.';
        console.error(err);
      } finally {
        submitBtn.disabled = false;
        submitBtn.classList.remove('opacity-70', 'cursor-not-allowed');
      }
    });

    wppBtn?.addEventListener('click', () => {
      const { ok, order, nombre, tel } = isFormValid();
      
      if (!ok) {
        state.textContent = 'Revisá los campos marcados antes de enviar.';
        return;
      }

      state.textContent = '';
      const mensaje = /** @type {HTMLTextAreaElement} */(document.getElementById('mensaje')).value.trim();
      const entrega = document.querySelector('input[name="entrega"]:checked')?.value || 'Retiro por local';
      
      let text = `¡Hola Cocina de Sol! Soy ${nombre}. Quería hacer el siguiente pedido:\n\n*Detalle del pedido:*\n${order.text}\n`;
      text += `\n*Entrega:* ${entrega}`;
      if (tel) text += `\n*Mi Teléfono:* ${tel}`;
      if (mensaje) text += `\n\n*Mensaje adicional:* ${mensaje}`;

      const encoded = encodeURIComponent(text);
      window.open(`https://wa.me/5491133544047?text=${encoded}`, '_blank');
    });
  </script>
</section>
