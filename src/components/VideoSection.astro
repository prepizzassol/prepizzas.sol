---
const {
  title = 'Así preparamos tus prepizzas',
  copy = 'Masa casera, fermentación justa y cocción pareja. Elegí tomate clásico o cebolla estilo fugazza.',
  src = '/video-prepizzas.webm',       // poné tu video en /public
  poster = '/poster.jpg',       // imagen de portada en /public     
} = Astro.props;
const WHATSAPP = 'https://wa.me/5491133544047?text=Hola%20!%20Quiero%20hacer%20un%20pedido%20de%20prepizzas%20';
---

<section id="video" class="relative overflow-hidden bg-bg py-16 md:py-24">
  <div class="container relative z-[3] grid items-center gap-12 md:grid-cols-2">
    <!-- Texto -->
    <div class="flex flex-col gap-6 text-center md:text-left">
      <h2 class="font-display text-text text-5xl md:text-6xl font-bold">{title}</h2>
      <p class="text-muted font-medium text-lg">{copy}</p>
      <div class="flex flex-wrap justify-center md:justify-start gap-4 mt-2">
        <a href={WHATSAPP} target="_blank" rel="noopener" class="btn text-xl tracking-wide bg-accent text-text">Hacer pedido</a>
        <a href="#sabores" class="btn text-xl tracking-wide bg-white text-text">Ver opciones</a>
      </div>
    </div>

    <!-- Video -->
    <div class="flex justify-center">
      <figure class="polaroid-frame rotate-[2deg] hover:rotate-0 transition-transform duration-300 w-full max-w-[500px]">
        <video
          id="prepizzasVideo"
          class="w-full h-auto block"
          src={src}
          poster={poster}
          playsinline
          muted
          loop
          preload
          controls
        >
          <track kind="captions" srcLang="es" label="Español"  default />
        </video>
        <p class="font-display text-center text-xl mt-4 font-bold text-text">Detrás de escena 🎥</p>
      </figure>
    </div>
  </div>

  <!-- Autoplay inteligente: play al entrar, pause al salir -->
  <script is:inline>
    const v = document.getElementById('prepizzasVideo');
    if (v) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach(async (e) => {
            try {
              if (e.isIntersecting) { await v.play(); }
              else { v.pause(); }
            } catch (_) {}
          });
        },
        { threshold: 0.5 }
      );
      io.observe(v);
    }
  </script>
</section>
