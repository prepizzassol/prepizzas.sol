---
// src/components/MenuCards.astro
---

<section id="menu" class="bg-[#F4F0E6] py-20 px-4">
  <div class="max-w-6xl mx-auto">
    <h2
      class="text-6xl md:text-8xl font-black text-[#D8423D] mb-12 text-center tracking-tighter"
    >
      EL MENÚ
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <div
        class="bg-white border-4 border-[#2A3A29] rounded-3xl p-6 flex flex-col items-center shadow-[8px_8px_0px_0px_rgba(42,58,41,1)] transition-transform hover:-translate-y-2"
      >
        <h3 class="text-2xl font-bold text-[#2A3A29] mb-2">Tomate Clásica</h3>
        <p class="text-center text-sm text-gray-600 mb-6">
          Salsa casera y condimentos
        </p>
        <img
          src="/images/prepizza-tomate.png"
          alt="Prepizza Tomate"
          class="w-48 h-48 object-cover rounded-full mb-6 border-2 border-[#D8423D]"
        />
        <div
          class="w-full flex justify-between items-center bg-[#2A3A29] text-[#F4F0E6] rounded-full px-6 py-3 font-bold cursor-pointer hover:bg-[#D8423D] transition"
        >
          <span>AGREGAR</span>
          <span>$2000</span>
        </div>
      </div>

      <div
        class="bg-white border-4 border-[#2A3A29] rounded-3xl p-6 flex flex-col items-center shadow-[8px_8px_0px_0px_rgba(42,58,41,1)] transition-transform hover:-translate-y-2"
      >
        <h3 class="text-2xl font-bold text-[#2A3A29] mb-2">Fugazza</h3>
        <p class="text-center text-sm text-gray-600 mb-6">
          Pura cebolla, puro sabor
        </p>
        <img
          src="/images/prepizza-cebolla.png"
          alt="Prepizza Cebolla"
          class="w-48 h-48 object-cover rounded-full mb-6 border-2 border-[#D8423D]"
        />
        <div
          class="w-full flex justify-between items-center bg-[#2A3A29] text-[#F4F0E6] rounded-full px-6 py-3 font-bold cursor-pointer hover:bg-[#D8423D] transition"
        >
          <span>AGREGAR</span>
          <span>$2000</span>
        </div>
      </div>

      <div
        class="bg-white border-4 border-[#2A3A29] rounded-3xl p-6 flex flex-col items-center shadow-[8px_8px_0px_0px_rgba(42,58,41,1)] transition-transform hover:-translate-y-2"
      >
        <h3 class="text-2xl font-bold text-[#2A3A29] mb-2">La Mixta</h3>
        <p class="text-center text-sm text-gray-600 mb-6">
          Mitad tomate, mitad cebolla
        </p>
        <img
          src="/images/prepizza-mixta.png"
          alt="Prepizza Mixta"
          class="w-48 h-48 object-cover rounded-full mb-6 border-2 border-[#D8423D]"
        />
        <div
          class="w-full flex justify-between items-center bg-[#2A3A29] text-[#F4F0E6] rounded-full px-6 py-3 font-bold cursor-pointer hover:bg-[#D8423D] transition"
        >
          <span>AGREGAR</span>
          <span>$2000</span>
        </div>
      </div>
    </div>
  </div>
</section>
