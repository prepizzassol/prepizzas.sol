---
// src/components/MenuCards.astro
---

<section id="sabores" class="bg-bg py-20 px-4">
  <div class="container mx-auto">
    <div class="flex justify-center mb-16">
      <h2 class="inline-block relative">
        <span class="text-5xl md:text-7xl font-display text-text font-bold text-center">Nuestras Pizzas</span>
        <!-- Subrayado decorativo SVG -->
        <svg class="absolute -bottom-4 left-0 w-full h-4 text-green" viewBox="0 0 100 10" preserveAspectRatio="none"><path d="M0 5 Q 50 10 100 5" stroke="currentColor" stroke-width="4" fill="none" stroke-linecap="round"/></svg>
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12">
      <!-- Tomate Clásica -->
      <div class="bg-green scrapbook-border p-8 flex flex-col items-center scrapbook-shadow transition-transform hover:-translate-y-2 relative">
        <!-- Badge Apto Freezer -->
        <div class="absolute -top-4 -right-4 bg-yellow scrapbook-border text-text font-bold px-4 py-2 text-sm rotate-6 flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2v20M2 12h20M20 16l-4-4 4-4M4 8l4 4-4 4M16 4l-4 4-4-4M8 20l4-4 4 4"/>
          </svg>
          Apto Freezer
        </div>

        <h3 class="text-3xl font-display font-bold text-text mb-2">Tomate Clásica</h3>
        <p class="text-center text-muted font-medium text-lg mb-6">Salsa casera y condimentos</p>
        <div class="relative mb-8">
          <img src="/images/prepizza-tomate.png" alt="Prepizza Tomate" class="w-48 h-48 object-cover rounded-full border-4 border-white scrapbook-shadow" />
        </div>
        
        <div class="w-full flex justify-between items-center bg-white text-text scrapbook-border px-6 py-3 font-bold hover:bg-yellow hover:-translate-y-1 transition-transform cursor-pointer">
          <span class="font-sans text-lg">AGREGAR</span>
          <span class="font-sans text-lg">$2000</span>
        </div>
      </div>

      <!-- Fugazza -->
      <div class="bg-green scrapbook-border p-8 flex flex-col items-center scrapbook-shadow transition-transform hover:-translate-y-2 relative">
        <!-- Badge Horno -->
        <div class="absolute -top-4 -left-4 bg-accent scrapbook-border text-text font-bold px-4 py-2 text-sm -rotate-6 flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>
          </svg>
          Al Horno
        </div>

        <h3 class="text-3xl font-display font-bold text-text mb-2">Fugazza</h3>
        <p class="text-center text-muted font-medium text-lg mb-6">Pura cebolla, puro sabor</p>
        <div class="relative mb-8">
          <img src="/images/prepizza-cebolla.png" alt="Prepizza Cebolla" class="w-48 h-48 object-cover rounded-full border-4 border-white scrapbook-shadow" />
        </div>

        <div class="w-full flex justify-between items-center bg-white text-text scrapbook-border px-6 py-3 font-bold hover:bg-yellow hover:-translate-y-1 transition-transform cursor-pointer">
          <span class="font-sans text-lg">AGREGAR</span>
          <span class="font-sans text-lg">$2000</span>
        </div>
      </div>

      <!-- La Mixta -->
      <div class="bg-green scrapbook-border p-8 flex flex-col items-center scrapbook-shadow transition-transform hover:-translate-y-2 relative">
        <!-- Badge -->
        <div class="absolute -top-4 -right-4 bg-yellow scrapbook-border text-text font-bold px-4 py-2 text-sm rotate-3 flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
          </svg>
          La Favorita
        </div>

        <h3 class="text-3xl font-display font-bold text-text mb-2">La Mixta</h3>
        <p class="text-center text-muted font-medium text-lg mb-6">Mitad tomate, mitad cebolla</p>
        <div class="relative mb-8">
          <img src="/images/prepizza-mixta.png" alt="Prepizza Mixta" class="w-48 h-48 object-cover rounded-full border-4 border-white scrapbook-shadow" />
        </div>

        <div class="w-full flex justify-between items-center bg-white text-text scrapbook-border px-6 py-3 font-bold hover:bg-yellow hover:-translate-y-1 transition-transform cursor-pointer">
          <span class="font-sans text-lg">AGREGAR</span>
          <span class="font-sans text-lg">$2000</span>
        </div>
      </div>
    </div>
  </div>
</section>
