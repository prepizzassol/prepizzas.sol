---
---

<section id="sobre-mi" class="relative overflow-hidden bg-bg py-16 md:py-24 border-b-[8px] border-text">
  <!-- Decorative circles -->
  <div class="absolute md:top-10 md:right-10 -top-10 -right-10 w-64 h-64 bg-accent rounded-full z-0 neo-border neo-shadow opacity-90"></div>
  <div class="absolute bottom-10 left-10 w-48 h-48 bg-yellow rounded-full z-0 neo-border neo-shadow hidden md:block"></div>

  <div class="container relative z-[3] grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
    
    <!-- Photo Column -->
    <div class="md:col-span-4 lg:col-span-5 relative flex justify-center group">
      <div class="relative z-10 w-full max-w-[320px] aspect-[4/5] neo-border rounded-xl overflow-hidden shadow-[12px_12px_0_rgba(17,17,17,1)] rotate-[-3deg] transition-transform duration-500 group-hover:rotate-0 bg-white">
        <img src="/images/sol-about.jpg" alt="Sol Piccininno" class="w-full h-full object-cover" />
      </div>
    </div>

    <!-- Text / Badges Column -->
    <div class="md:col-span-8 lg:col-span-7 flex flex-col items-center md:items-start gap-8 z-10">
      
      <div class="relative inline-block">
        <h2 class="text-text font-script text-6xl md:text-8xl drop-shadow-[4px_4px_0_rgba(255,214,0,1)] text-center md:text-left mt-4 md:mt-0">
          ¡Hola! Soy Sol
        </h2>
      </div>

      <div class="flex flex-wrap justify-center md:justify-start gap-4 mt-2">
        <!-- Badges -->
        <span class="badge w-fit bg-primary text-white font-bold text-xl md:text-2xl px-6 py-3 rounded-2xl neo-border neo-shadow-sm rotate-[-2deg] hover:scale-105 hover:rotate-0 transition-transform cursor-default">
          Emprendedora & cocinera 🧑‍🍳
        </span>
        <span class="badge w-fit bg-white text-text font-bold text-xl md:text-2xl px-6 py-3 rounded-2xl neo-border neo-shadow-sm rotate-[3deg] hover:scale-105 hover:rotate-0 transition-transform cursor-default">
          Soy de Villa Adelina 📍
        </span>
        <span class="badge w-fit bg-accent text-white font-bold text-xl md:text-2xl px-6 py-3 rounded-2xl neo-border neo-shadow-sm rotate-[-1deg] hover:scale-105 hover:rotate-0 transition-transform cursor-default">
          Prepizzas & Empanadas 🍕
        </span>
        <span class="badge w-fit bg-yellow text-text font-bold text-xl md:text-2xl px-6 py-3 rounded-2xl neo-border neo-shadow-sm rotate-[2deg] hover:scale-105 hover:rotate-0 transition-transform cursor-default">
          Madre de 3 perrhijos 🐾
        </span>
        <span class="badge w-fit bg-white text-text font-bold text-xl md:text-2xl px-6 py-3 rounded-2xl neo-border neo-shadow-sm rotate-[-3deg] hover:scale-105 hover:rotate-0 transition-transform cursor-default">
          Tengo 30 años 🎂
        </span>
        <span class="badge w-fit bg-primary text-white font-bold text-xl md:text-2xl px-6 py-3 rounded-2xl neo-border neo-shadow-sm rotate-[1deg] hover:scale-105 hover:rotate-0 transition-transform cursor-default">
          12 años haciendo lo que amo ❤️
        </span>
        <span class="badge w-fit bg-accent text-white font-bold text-xl md:text-2xl px-6 py-3 rounded-2xl neo-border neo-shadow-sm rotate-[-2deg] hover:scale-105 hover:rotate-0 transition-transform md:w-auto text-center cursor-default">
          El mate y la música, mi compañía 🧉🎶
        </span>
      </div>

    </div>
  </div>
</section>
