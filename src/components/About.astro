---
---

<section id="sobre-mi" class="relative overflow-hidden bg-bg py-16 md:py-24">
  <!-- Decorative circles -->
  <div class="absolute md:top-10 md:right-10 -top-10 -right-10 w-64 h-64 bg-accent rounded-full z-0 opacity-50 blur-2xl"></div>
  <div class="absolute bottom-10 left-10 w-48 h-48 bg-yellow rounded-full z-0 hidden md:block opacity-50 blur-2xl"></div>

  <div class="container relative z-[3] grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
    
    <!-- Photo Column -->
    <div class="md:col-span-4 lg:col-span-5 relative flex justify-center group">
      <div class="polaroid-frame rotate-[-3deg] transition-transform duration-500 group-hover:rotate-0 w-full max-w-[320px]">
        <img src="/images/sol-about.jpg" alt="Sol Piccininno" class="w-full h-auto aspect-[4/5] object-cover" />
        <p class="font-display text-center text-xl mt-4 font-bold text-text">En mi cocina 🤍</p>
      </div>
    </div>

    <!-- Text / Badges Column -->
    <div class="md:col-span-8 lg:col-span-7 flex flex-col items-center md:items-start gap-8 z-10">
      
      <div class="relative inline-block">
        <h2 class="text-text font-display text-5xl md:text-7xl text-center md:text-left mt-4 md:mt-0 font-bold">
          ¡Hola! Soy Sol
        </h2>
        <svg class="w-full h-3 text-yellow mt-2" viewBox="0 0 100 10" preserveAspectRatio="none"><path d="M0 5 Q 50 10 100 5" stroke="currentColor" stroke-width="4" fill="none" stroke-linecap="round"/></svg>
      </div>

      <div class="flex flex-wrap justify-center md:justify-start gap-4 mt-2">
        <!-- Badges -->
        <span class="badge bg-green text-text px-6 py-2 rotate-[-2deg] hover:scale-105 hover:rotate-0 transition-transform cursor-default scrapbook-shadow scrapbook-border text-lg font-bold">
          Emprendedora & cocinera 🧑‍🍳
        </span>
        <span class="badge bg-white text-text px-6 py-2 rotate-[3deg] hover:scale-105 hover:rotate-0 transition-transform cursor-default scrapbook-shadow scrapbook-border text-lg font-bold">
          Soy de Villa Adelina 📍
        </span>
        <span class="badge bg-accent text-text px-6 py-2 rotate-[-1deg] hover:scale-105 hover:rotate-0 transition-transform cursor-default scrapbook-shadow scrapbook-border text-lg font-bold">
          Prepizzas & Empanadas 🍕
        </span>
        <span class="badge bg-yellow text-text px-6 py-2 rotate-[2deg] hover:scale-105 hover:rotate-0 transition-transform cursor-default scrapbook-shadow scrapbook-border text-lg font-bold">
          Madre de 3 perrhijos 🐾
        </span>
        <span class="badge bg-white text-text px-6 py-2 rotate-[-3deg] hover:scale-105 hover:rotate-0 transition-transform cursor-default scrapbook-shadow scrapbook-border text-lg font-bold">
          Tengo 30 años 🎂
        </span>
        <span class="badge bg-purple text-text px-6 py-2 rotate-[1deg] hover:scale-105 hover:rotate-0 transition-transform cursor-default scrapbook-shadow scrapbook-border text-lg font-bold">
          12 años haciendo lo que amo ❤️
        </span>
        <span class="badge bg-green text-text px-6 py-2 rotate-[-2deg] hover:scale-105 hover:rotate-0 transition-transform md:w-auto text-center cursor-default scrapbook-shadow scrapbook-border text-lg font-bold">
          El mate y la música, mi compañía 🧉🎶
        </span>
      </div>

    </div>
  </div>
</section>
