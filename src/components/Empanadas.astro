---
// src/components/Empanadas.astro
---

<section
  id="empanadas"
  class="bg-accent text-text py-16 md:py-24 px-4 relative overflow-hidden"
>
  <!-- Contenido principal -->
  <div
    class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center relative z-10"
  >
    <div class="text-center md:text-left flex flex-col gap-6">
      <h2
        class="text-5xl md:text-8xl font-display font-bold leading-[0.9] -rotate-2"
      >
        Nuestras<br />Empanadas
      </h2>
      <p
        class="text-lg md:text-2xl font-bold bg-white text-text scrapbook-border scrapbook-shadow inline-block px-4 py-2 rotate-1 center"
      >
        Estilo canastita, extra rellenas.
      </p>

      <div class="mt-4">
        <span
          class="bg-yellow text-text font-display text-2xl md:text-3xl px-6 py-2 scrapbook-border scrapbook-shadow rotate-[-3deg] inline-block font-bold"
        >
          $18.000 / Docena
        </span>
      </div>

      <div class="mt-8 flex flex-col gap-4">
        <div
          class="bg-white text-text scrapbook-border scrapbook-shadow p-6 text-xl font-bold"
        >
          <ul class="flex flex-col gap-4">
            <li class="flex items-center gap-3">
              <!-- SVG Icon -->
              <svg
                class="w-6 h-6 text-green"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"
                ></path></svg
              >
              Muzzarella y Jamón Cocido
            </li>
            <li class="flex items-center gap-3">
              <svg
                class="w-6 h-6 text-green"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"
                ></path></svg
              >
              Muzzarella y Verdura
            </li>
            <li class="flex items-center gap-3">
              <svg
                class="w-6 h-6 text-green"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"
                ></path></svg
              >
              Muzzarella y Cebolla
            </li>
            <li class="flex items-center gap-3">
              <svg
                class="w-6 h-6 text-green"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"
                ></path></svg
              >
              Caprese
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Imagen lado derecho -->
    <div class="relative flex justify-center mt-12 md:mt-0 z-10 group">
      <div
        class="polaroid-frame rotate-[6deg] group-hover:rotate-0 transition-transform duration-500 w-full max-w-[600px] md:max-w-[450px]"
      >
        <img
          src="/images/empanadas-3.png"
          alt="Canastita Capresse dorada crujiente"
          class="w-full h-auto aspect-square object-cover"
        />
        <p class="font-display text-center text-xl mt-4 font-bold">
          100% Hechas a mano
        </p>
      </div>
    </div>
  </div>
</section>
