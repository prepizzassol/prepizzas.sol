---
// src/components/Empanadas.astro
---

<section
  id="empanadas"
  class="bg-primary text-bg py-24 px-4 border-b-[8px] border-text relative overflow-hidden"
>
  <!-- Contenido principal -->
  <div
    class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center relative z-10"
  >
    <div class="text-center md:text-left flex flex-col gap-6">
      <h2
        class="text-12xl md:text-8xl font-display text-white drop-shadow-[6px_3px_0_rgba(237,208,83,0.4)] leading-[0.9] -rotate-2"
      >
        Nuestras<br />Empanadas
      </h2>
      <p
        class="text-2xl md:text-3xl font-bold bg-yellow text-text neo-border neo-shadow-sm inline-block p-4 rounded-xl rotate-1 self-start"
      >
        Estilo canastita, extra rellenas.
      </p>

      <div class="mt-4">
        <span
          class="bg-accent text-white font-display text-4xl px-6 py-3 rounded-full neo-border neo-shadow-sm rotate-[-3deg] inline-block"
        >
          $18.000 / Docena
        </span>
      </div>

      <div class="mt-8 flex flex-col gap-4">
        <div
          class="bg-white text-text neo-border neo-shadow-md rounded-[2rem] p-6 text-xl font-bold"
        >
          <ul class="flex flex-col gap-3">
            <li class="flex items-center gap-3">
              <span
                class="w-4 h-4 bg-yellow rounded-full border-2 border-text inline-block"
              ></span>
              Muzzarella y Jamón Cocido
            </li>
            <li class="flex items-center gap-3">
              <span
                class="w-4 h-4 bg-accent rounded-full border-2 border-text inline-block"
              ></span>
              Muzzarella y Verdura
            </li>
            <li class="flex items-center gap-3">
              <span
                class="w-4 h-4 bg-primary rounded-full border-2 border-text inline-block"
              ></span>
              Muzzarella y Cebolla
            </li>
            <li class="flex items-center gap-3">
              <span
                class="w-4 h-4 bg-yellow rounded-full border-2 border-text inline-block"
              ></span>
              Caprese
            </li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Imagen lado derecho -->
    <div class="relative flex justify-center mt-12 md:mt-0 z-10 group">
      <div
        class="absolute w-80 h-80 md:w-[450px] md:h-[450px] bg-yellow rounded-full neo-border neo-shadow-lg transition-transform duration-500"
      >
      </div>
      <img
        src="/images/empanadas-hero-3.png"
        alt="Canastita Capresse dorada crujiente"
        class="relative z-10 w-full max-w-[500px] md:max-w-[600px] drop-shadow-[20px_20px_0_rgba(17,17,17,0.8)] rotate-12 transition-transform duration-500 group-hover:scale-110 group-hover:rotate-6"
      />
    </div>
  </div>
</section>
