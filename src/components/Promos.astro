---
const {
  img = "/images/promocion.webp", // poné la imagen del cliente en /public
  whatsapp = "https://wa.me/5491133544047?text=Hola!%20Vi%20la%20promo%20de%20Cocina%20de%20Sol%20🍕%20y%20quiero%20hacer%20mi%20pedido!",
} = Astro.props;
---

<section id="promos" class="relative overflow-hidden bg-bg py-16 md:py-24">
  <div
    class="container relative z-[3] grid grid-cols-1 md:grid-cols-2 gap-12 items-center"
  >
    <!-- Texto (izquierda en desktop / primero en mobile) -->
    <div class="order-1 md:order-none flex flex-col gap-6">
      <div
        class="inline-block px-4 py-2 bg-yellow scrapbook-border text-text font-bold text-sm rotate-[2deg] self-start"
      >
        Llevá más, pagá menos
      </div>

      <h2
        class="font-display text-text text-4xl md:text-6xl leading-[1.1] font-bold"
      >
        Promociones que rinden
      </h2>

      <p class="text-muted font-medium text-lg max-w-prose">
        Prepizzas caseras listas para el horno o la parrilla. ¡Ideales para
        freezer y para resolver en el día!
      </p>

      <!-- Bloque de precios prolijo -->
      <div class="rounded-3xl bg-white p-6 scrapbook-border scrapbook-shadow">
        <ul class="space-y-6">
          <li class="flex items-center justify-between gap-4">
            <div class="text-base font-bold text-text">
              Llevando <strong>5 Prepizzas</strong> o más (c/u)
            </div>
            <div
              class="shrink-0 inline-flex items-center bg-green scrapbook-border px-4 py-1 text-text text-lg font-bold"
            >
              $1800
            </div>
          </li>
          <li class="flex items-center justify-between gap-4">
            <div class="text-base font-bold text-text">
              Llevando <strong>6 Pizzas Individuales</strong> o más
            </div>
            <div
              class="shrink-0 inline-flex items-center bg-green scrapbook-border px-4 py-1 text-text text-lg font-bold"
            >
              $900
            </div>
          </li>
          <li class="flex items-center justify-between gap-4">
            <div class="text-base font-bold text-text">
              Llevando <strong>3 docenas de Pizzetas</strong>
            </div>
            <div
              class="shrink-0 inline-flex items-center bg-green scrapbook-border px-4 py-1 text-text text-lg font-bold"
            >
              $10.000
            </div>
          </li>
        </ul>

        <div class="mt-6 flex flex-wrap gap-4 text-sm font-bold text-muted">
          <div class="inline-flex items-center gap-2">
            <svg
              class="w-4 h-4 text-text"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="2"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path></svg
            > Pedidos en el día
          </div>
          <div class="inline-flex items-center gap-2">
            <svg
              class="w-4 h-4 text-text"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="2"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M5 13l4 4L19 7"></path></svg
            > Aptas freezer
          </div>
        </div>

        <div class="mt-8 flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
          <a
            href={whatsapp}
            target="_blank"
            rel="noopener"
            class="btn w-full sm:w-auto justify-center bg-accent text-text">Hacer pedido</a
          >
          <a href="#contacto" class="btn w-full sm:w-auto justify-center bg-white text-text">Consultar</a>
        </div>
      </div>
    </div>

    <!-- Imagen (derecha en desktop / segunda en mobile) -->
    <div class="order-2 md:order-none flex justify-center md:justify-end">
      <figure
        class="polaroid-frame rotate-[-3deg] hover:rotate-0 transition-transform duration-300 w-full max-w-[450px]"
      >
        <img
          src={img}
          alt="Promoción vigente"
          class="w-full h-auto aspect-square object-contain"
          loading="lazy"
        />
        <p class="font-display text-center text-xl mt-4 font-bold text-text">
          ¡Aprovechá hoy!
        </p>
      </figure>
    </div>
  </div>
</section>
