---
const opciones = [
  { titulo: 'Tomate Clásica', desc: 'Salsa casera y condimentos', precio: '$2000', img: '/images/hero-pizza-4.jpeg', color: 'bg-yellow' },
  { titulo: 'Cebolla (Fugazza)', desc: 'Cebolla dorada + orégano', precio: '$2000', img: '/images/hero-pizza-2.jpeg', color: 'bg-accent' },
  { titulo: 'Mixta', desc: '½ Tomate • ½ Cebolla', precio: '$2000', img: '/images/hero-pizza-1.jpeg', color: 'bg-[#FF9B54]' },
  { titulo: 'Pizzetas Cebolla', desc: 'Ideales para picadas', precio: '$3800 / La docena', img: '/images/pizzeta-cebolla-1.webp', color: 'bg-[#4CAF50]' },
  { titulo: 'Pizzetas Tomate', desc: 'Ideales para picadas', precio: '$3800 / La docena', img: '/images/pizzeta-tomate.webp', color: 'bg-[#00BCD4]' }
];
---
<section id="sabores" class="relative bg-bg py-16 md:py-24 border-b-[8px] border-text">
  <div class="container relative z-[3]">
    <div class="text-center mb-12">
      <h2 class="font-display text-text text-5xl md:text-7xl drop-shadow-[4px_4px_0_rgba(230,57,70,1)] -rotate-2 inline-block">Nuestras Pizzas</h2>
      <p class="text-text font-bold text-xl mt-4 bg-yellow inline-block p-2 neo-shadow-sm neo-border rounded-xl rotate-1">Elegí tu base favorita. ¡Aptas freezer!</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
      {opciones.map((o, i) => {
        const rotationMap = ['-rotate-2', 'rotate-1', 'rotate-2', '-rotate-1', 'rotate-3'];
        const delayMap = ['duration-300', 'duration-500', 'duration-[400ms]', 'duration-700', 'duration-300'];
        const rot = rotationMap[i % rotationMap.length];
        const dur = delayMap[i % delayMap.length];
        const bgColor = i % 2 === 0 ? 'bg-[#FFD166]' : 'bg-[#FF9B54]';

        return (
          <article
            class={`group relative bg-white neo-brutal overflow-hidden transition-transform ${rot} ${dur} hover:rotate-0 hover:-translate-y-2 flex flex-col`}
          >
            <!-- Imagen Collage -->
            <div class={`aspect-square sm:aspect-[4/3] ${bgColor} border-b-[3px] border-text relative flex justify-center items-center overflow-hidden p-6`}>
               <!-- Decorative Circle Backend -->
               <div class="absolute w-[90%] h-[90%] bg-white/20 rounded-full blur-xl"></div>
                <img
                  src={o.img}
                  alt={o.titulo}
                  loading="lazy"
                  decoding="async"
                  class="relative z-10 w-[100%] h-[100%] sm:w-[90%] sm:h-[90%] lg:w-[95%] lg:h-[95%] object-cover rounded-full border-[4px] border-text drop-shadow-[5px_5px_0_rgba(17,17,17,0.8)] transition-transform duration-300 group-hover:scale-110"
                />
            </div>

            <!-- Contenido -->
            <div class="p-6 flex flex-col gap-2 relative bg-white z-20 flex-1">
              <h3 class="font-display text-2xl md:text-3xl tracking-wide">{o.titulo}</h3>
              <p class="text-lg font-bold text-muted">{o.desc}</p>

              <div class="mt-auto pt-4 flex items-center justify-between">
                <span class="inline-flex items-center rounded-full px-4 py-1 bg-yellow neo-border neo-shadow-sm text-text text-lg font-bold">
                  {o.precio}
                </span>
              </div>
            </div>
          </article>
        )
      })}

      <!-- 6to Espacio: Sello Identidad HTML -->
      <div class="flex flex-col items-center justify-center p-4 min-h-[300px]">
        <div class="w-full max-w-[250px] aspect-square rounded-full bg-yellow border-[6px] border-text drop-shadow-[10px_10px_0_rgba(17,17,17,0.8)] flex flex-col items-center justify-center rotate-[-4deg] transition-transform duration-500 hover:rotate-3 hover:scale-105 p-6 text-center select-none cursor-default group">
           <h2 class="font-display text-[90px] md:text-[120px] text-text z-10 pt-4 tracking-tighter group-hover:scale-110 transition-transform duration-300">SP</h2>
        </div>
      </div>

    </div>
  </div>
</section>
