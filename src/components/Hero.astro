---
const WHATSAPP =
  "https://wa.me/5491133544047?text=Hola%20!%20Quiero%20hacer%20un%20pedido%20de%20prepizzas%20";
import HeroBackground from "./HeroBackground.jsx";
---

<section
  id="inicio"
  class="relative overflow-hidden min-h-[85vh] flex flex-col justify-center"
>
  <!-- Fondo Carrusel Animado (Position absolute forzado) -->
  <div class="absolute inset-0 z-0 w-full h-full">
    <HeroBackground client:load />
  </div>

  <!-- Overlay muy sutil, en tonos crema para asegurar legibilidad del texto oscuro -->
  <div class="absolute inset-0 z-[1] bg-bg/20 backdrop-blur-[0.5px]"></div>

  <div
    class="container relative z-[3] py-16 md:py-24 flex flex-col items-center text-center"
  >
    <!-- Elementos Flotantes Scrapbook (Desktop) -->
    <div class="absolute top-10 left-4 lg:left-10 hidden md:block">
      <div
        class="px-4 py-2 bg-accent scrapbook-border scrapbook-shadow text-text font-bold text-lg rotate-[-8deg]"
      >
        ¡Recién salidas!
      </div>
    </div>

    <div class="absolute bottom-10 right-4 lg:right-10 hidden md:block">
      <div
        class="w-28 h-28 bg-yellow rounded-full border-4 border-text flex items-center justify-center scrapbook-shadow rotate-[12deg]"
      >
        <span
          class="font-display text-text font-bold text-2xl leading-none text-center"
          >100%<br />Casero</span
        >
      </div>
    </div>

    <!-- Contenido Principal: Textos sobre el carrusel -->
    <div class="flex flex-col items-center gap-6 max-w-4xl mx-auto z-10 w-full">
      <div
        class="inline-block md:hidden px-4 py-2 bg-yellow scrapbook-border scrapbook-shadow text-text font-bold text-sm rotate-[-3deg] mb-2"
      >
        ¡Recién salidas del horno!
      </div>

      <h1
        class="text-text font-display leading-[1.1] text-5xl sm:text-6xl md:text-8xl lg:text-[7.5rem] font-bold drop-shadow-md"
      >
        <span class="text-[#241c17]">Las mejores</span>
        <br />
        <span
          id="hero-underline"
          class="inline-block relative z-10 text-[#241c17]"
          >Prepizzas caseras</span
        >
      </h1>

      <!-- Caja de descripción pequeña estilo scrapbook -->
      <div
        class="bg-bg/95 p-4 md:p-6 scrapbook-border scrapbook-shadow max-w-2xl mt-4 rotate-1"
      >
        <p class="text-text font-bold text-lg md:text-xl">
          Tamaño grande, pizzetas e individuales. <br />
          ¡Aptas freezer y listas para el horno o parrilla!
        </p>
      </div>

      <div class="flex flex-col sm:flex-row w-full sm:w-auto px-4 sm:px-0 justify-center gap-4 sm:gap-6 mt-6">
        <a
          href={WHATSAPP}
          target="_blank"
          rel="noopener"
          class="btn w-full sm:w-auto justify-center text-xl tracking-wide bg-accent text-text scrapbook-shadow scrapbook-border hover:-translate-y-1 transition-transform"
        >
          Hacé tu pedido
        </a>
        <a
          href="#sabores"
          class="btn w-full sm:w-auto justify-center text-xl tracking-wide bg-white text-text scrapbook-shadow scrapbook-border hover:-translate-y-1 transition-transform"
        >
          Ver Menú
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  import { annotate } from "rough-notation";

  document.addEventListener("DOMContentLoaded", () => {
    const el = document.getElementById("hero-underline");
    if (el) {
      const annotation = annotate(el, {
        type: "underline",
        color: "#FFDAB9",
        strokeWidth: 8,
        padding: 2,
      });
      setTimeout(() => {
        annotation.show();
      }, 500);
    }
  });
</script>
